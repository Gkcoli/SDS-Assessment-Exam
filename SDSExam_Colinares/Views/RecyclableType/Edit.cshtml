@model SDSExam_Colinares.Models.RecyclableType
@{
    ViewBag.Title = "Edit Recyclable Type";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .page-title { font-size:2.8rem; font-weight:800; text-transform:uppercase; line-height:1; margin-bottom:.4rem; }
    .page-title .hl { color:var(--warn); }
    .page-sub { font-family:var(--mono); font-size:.7rem; color:var(--muted); letter-spacing:.1em; margin-bottom:2rem; }
    .form-card { background:var(--card); border:1px solid var(--border); border-radius:6px; max-width:520px; overflow:hidden; }
    .form-header { background:var(--surface); border-bottom:1px solid var(--border); padding:1rem 1.5rem; display:flex; align-items:center; justify-content:space-between; }
    .form-header-title { font-family:var(--mono); font-size:.72rem; letter-spacing:.15em; text-transform:uppercase; color:var(--muted); }
    .form-header-title strong { color:var(--warn); }
    .dot { width:8px; height:8px; border-radius:50%; background:var(--warn); box-shadow:0 0 8px var(--warn); }
    .form-body { padding:1.5rem; display:flex; flex-direction:column; gap:1.1rem; }
    .field { display:flex; flex-direction:column; gap:.4rem; }
    .field label { font-family:var(--mono); font-size:.63rem; letter-spacing:.15em; text-transform:uppercase; color:var(--muted); }
    .field input { background:var(--surface); border:1px solid var(--border); color:var(--text); font-family:var(--mono); font-size:.85rem; padding:.65rem .9rem; border-radius:3px; outline:none; transition:border .2s; width:100%; }
    .field input:focus { border-color:var(--warn); box-shadow:0 0 0 3px rgba(255,160,64,.1); }
    .field-row { display:grid; grid-template-columns:1fr 1fr; gap:.75rem; }
    .field-error { font-family:var(--mono); font-size:.68rem; color:var(--danger); }
    .form-footer { padding:1rem 1.5rem; border-top:1px solid var(--border); display:flex; gap:.75rem; }
    .btn { display:inline-flex; align-items:center; justify-content:center; font-family:var(--sans); font-weight:700; font-size:.82rem; letter-spacing:.14em; text-transform:uppercase; padding:.65rem 1.5rem; border:1px solid transparent; border-radius:3px; cursor:pointer; text-decoration:none; transition:all .18s; flex:1; }
    .btn-warn { background:var(--warn); color:#000; }
    .btn-warn:hover { background:#ffb060; color:#000; }
    .btn-ghost { background:transparent; color:var(--muted); border-color:var(--border); }
    .btn-ghost:hover { color:var(--text); }
</style>

<div class="page-title"><span class="hl">Edit</span> Recyclable Type</div>
<div class="page-sub">// EDITING ID: @Model.Id</div>

@using (Html.BeginForm("Edit", "RecyclableType", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.Id)
    <div class="form-card">
        <div class="form-header">
            <span class="form-header-title">// <strong>EDIT</strong> TYPE</span>
            <div class="dot"></div>
        </div>
        <div class="form-body">
            @Html.ValidationSummary(true, "", new { @class = "field-error" })
            <div class="field">
                <label>Type Name</label>
                @Html.TextBoxFor(m => m.Type, new { placeholder = "e.g. Plastic" })
                @Html.ValidationMessageFor(m => m.Type, "", new { @class = "field-error" })
            </div>
            <div class="field">
                <label>Rate per kg (&#8369;)</label>
                @Html.TextBoxFor(m => m.Rate, new { placeholder = "0.00", type = "number", step = "0.01", min = "0" })
                @Html.ValidationMessageFor(m => m.Rate, "", new { @class = "field-error" })
            </div>
            <div class="field-row">
                <div class="field">
                    <label>Min kg</label>
                    @Html.TextBoxFor(m => m.MinKg, new { placeholder = "0.00", type = "number", step = "0.01", min = "0" })
                    @Html.ValidationMessageFor(m => m.MinKg, "", new { @class = "field-error" })
                </div>
                <div class="field">
                    <label>Max kg</label>
                    @Html.TextBoxFor(m => m.MaxKg, new { placeholder = "0.00", type = "number", step = "0.01", min = "0" })
                    @Html.ValidationMessageFor(m => m.MaxKg, "", new { @class = "field-error" })
                </div>
            </div>
        </div>
        <div class="form-footer">
            <button type="submit" class="btn btn-warn">Update</button>
            <a href="@Url.Action("Index")" class="btn btn-ghost">Cancel</a>
        </div>
    </div>
}
